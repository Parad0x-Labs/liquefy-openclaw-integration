#!/usr/bin/env bash
# --- $NULL SOVEREIGN SDK CLI WRAPPER ---
# Policy: Data Sovereignty / Path C (Public Recovery)
set -euo pipefail

IMAGE="nullaai/liquefy-decoder-public@sha256:b7a0499f38d192e7333c760fcf8e429abcff83e58610259841f2ffb525c02935"
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

resolve_python() {
  local -a candidates=()

  if [[ -n "${PYTHON:-}" ]]; then
    candidates+=("${PYTHON}")
  fi

  candidates+=(
    "$ROOT_DIR/.venv/bin/python"
    "$ROOT_DIR/.venv/bin/python3"
    "/opt/homebrew/bin/python3"
    "/usr/local/bin/python3"
    "/usr/bin/python3"
    "/bin/python3"
  )

  local resolved=""
  resolved="$(command -v python3 2>/dev/null || true)"
  if [[ -n "$resolved" ]]; then
    candidates+=("$resolved")
  fi

  resolved="$(command -v python 2>/dev/null || true)"
  if [[ -n "$resolved" ]]; then
    candidates+=("$resolved")
  fi

  local candidate
  for candidate in "${candidates[@]}"; do
    if [[ -n "$candidate" && -x "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}

PYTHON_BIN="$(resolve_python || true)"

usage() {
  cat <<EOF
Usage:
  ./liquefy version
  ./liquefy verify <archive>
  ./liquefy decompress <archive> <output>
  ./liquefy search <vault_dir> --query "<expr>" [--limit N] [--ignore-case] [--regex] [--json]
  ./liquefy openclaw --workspace ~/.openclaw --out ./openclaw-vault [--verify-mode full|fast|off] [--workers N] [--secure]
  ./liquefy openclaw run --workspace ~/.openclaw --cmd "openclaw run task.md" [--json]
  ./liquefy agents <list|show|map|scaffold> [options]
  ./liquefy state-guard <init|check|checkpoint|status|recover> <workspace> [options]
  ./liquefy history-guard <init|set-approval-token|pull-once|watch|gate-action|status> [options]
  ./liquefy redact <scan|apply|profile> <path> [--out DIR] [--json]
  ./liquefy denoise <filter|stats|extract> <path> [--out DIR] [--trace-id ID] [--json]
  ./liquefy capsule build --dir <trace_dir> [--out DIR|FILE] [--json]
  ./liquefy capsule prime --workspace <workspace> [--trace-dir <trace_dir>] [--json]
  ./liquefy safe-run --workspace <workspace> --cmd "<command>" [--json]
  ./liquefy context-gate <compile|history> [options]
  ./liquefy sign <sign|verify-signature> <vault_dir> [--json]

Notes:
  - decode/verify/decompress run in the public decode-only appliance.
  - All other commands run local Python tools from this repo.
  - Appliance execution runs offline: --network=none, read-only rootfs, dropped caps.
EOF
}

require_python() {
  if [[ -z "$PYTHON_BIN" ]]; then
    echo "ERROR: Could not locate a usable Python interpreter." >&2
    echo "Tried repo .venv, \$PYTHON, and common system paths." >&2
    exit 2
  fi
}

cmd="${1:-}"
if [[ -z "$cmd" ]]; then usage; exit 2; fi

case "$cmd" in
  version)
    if ! command -v docker >/dev/null 2>&1; then
      echo "ERROR: Docker is required. Please install Docker to run the hardened conduction environment." >&2
      exit 2
    fi
    echo "[+] Ensuring latest hardened machine is available..."
    docker pull "$IMAGE" >/dev/null
    docker run --rm --network=none --read-only --cap-drop=ALL "$IMAGE" version
    ;;
  verify)
    if ! command -v docker >/dev/null 2>&1; then
      echo "ERROR: Docker is required. Please install Docker to run the hardened conduction environment." >&2
      exit 2
    fi
    archive="${2:-}"
    [[ -n "$archive" ]] || { usage; exit 2; }
    echo "[+] Pulling decoder machine..."
    docker pull "$IMAGE" >/dev/null
    docker run --rm --network=none --read-only --cap-drop=ALL \
      -v "$(pwd)":/data:rw \
      "$IMAGE" verify "/data/$archive"
    ;;
  decompress)
    if ! command -v docker >/dev/null 2>&1; then
      echo "ERROR: Docker is required. Please install Docker to run the hardened conduction environment." >&2
      exit 2
    fi
    archive="${2:-}"
    output="${3:-}"
    [[ -n "$archive" && -n "$output" ]] || { usage; exit 2; }
    echo "[+] Pulling decoder machine..."
    docker pull "$IMAGE" >/dev/null
    docker run --rm --network=none --read-only --cap-drop=ALL \
      -v "$(pwd)":/data:rw \
      "$IMAGE" decompress "/data/$archive" -o "/data/$output"
    ;;
  search)
    require_python
    vault_dir="${2:-}"
    [[ -n "$vault_dir" ]] || { usage; exit 2; }
    shift 2
    exec "$PYTHON_BIN" "$ROOT_DIR/tools/tracevault_search.py" "$vault_dir" "$@"
    ;;
  openclaw)
    require_python
    shift
    exec "$PYTHON_BIN" "$ROOT_DIR/tools/liquefy_openclaw.py" "$@"
    ;;
  agents)
    require_python
    shift
    exec "$PYTHON_BIN" "$ROOT_DIR/tools/liquefy_agents.py" "$@"
    ;;
  state-guard)
    require_python
    shift
    exec "$PYTHON_BIN" "$ROOT_DIR/tools/liquefy_state_guard.py" "$@"
    ;;
  history-guard)
    require_python
    shift
    exec "$PYTHON_BIN" "$ROOT_DIR/tools/liquefy_history_guard.py" "$@"
    ;;
  redact)
    require_python
    shift
    exec "$PYTHON_BIN" "$ROOT_DIR/tools/liquefy_redact.py" "$@"
    ;;
  denoise)
    require_python
    shift
    exec "$PYTHON_BIN" "$ROOT_DIR/tools/liquefy_denoise.py" "$@"
    ;;
  capsule)
    require_python
    shift
    exec "$PYTHON_BIN" "$ROOT_DIR/tools/liquefy_context_capsule.py" "$@"
    ;;
  safe-run)
    require_python
    shift
    exec "$PYTHON_BIN" "$ROOT_DIR/tools/liquefy_safe_run.py" "$@"
    ;;
  context-gate)
    require_python
    shift
    exec "$PYTHON_BIN" "$ROOT_DIR/tools/liquefy_context_gate.py" "$@"
    ;;
  sign)
    require_python
    shift
    exec "$PYTHON_BIN" "$ROOT_DIR/tools/liquefy_sign.py" "$@"
    ;;
  *)
    usage; exit 2
    ;;
esac
